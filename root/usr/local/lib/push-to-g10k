#!/usr/bin/with-contenv bash

REF="${1}"
REMOTE="${2}"
EVENT="${3}"

CACHEDIR=/etc/puppetlabs/code/cache
BASEDIR=/etc/puppetlabs/code/environments
STAGINGBASE=/etc/puppetlabs/code/environments-staging
PUPPET_SSLDIR=/etc/puppetlabs/puppet/ssl

TITLE="${PUPPET_SERVER%%.*}"
: "${TITLE:=G10K}"

r10kconf="$(mktemp)"
trap "rm -f ${r10kconf}" 0 1 2 3 13 15

notify () {
    local rc=${1}
    local branch=${2}
    local event

    if [ -n "${3}" ]; then
        event="${3} "
    fi

    if [ -f ./.apprise.yml -a -x /usr/bin/apprise ]; then
        echo "Sending notification with apprise ${rc} ${branch} ${3}'"
        if [ ${rc} -eq 0 ]; then
            local title="${TITLE} ${event}SUCCESS"
        else
            local title="${TITLE} ${event}FAILED: ${rc}"
        fi
        /usr/bin/apprise --config ${PWD}/.apprise.yml --title "${title}" --body "Branch: ${branch}"
    elif [ -x ./notify ]; then
        echo "Sending notification with '${PWD}/notify ${rc} ${branch} ${3}'"
        ./notify ${rc} ${branch} ${REMOTE}
    fi
}

deploy_branch () {
    local branch="${1}"
    local live="${BASEDIR}/${branch}"
    local staging="${STAGINGBASE}/${branch}"
    local timestamp=$(date +%Y%m%d%H%M%S)
    local newdir="${STAGINGBASE}/${branch}.${timestamp}"

    mkdir -p "${STAGINGBASE}"

    # Seed staging with hardlinks from current live content
    local current
    current=$(readlink "${live}" 2>/dev/null)

    # Clean up any leftover staging dirs from previous failed runs,
    # but not the directory the live symlink currently points to
    for old in "${STAGINGBASE}/${branch}."*; do
        [ "${old}" != "${current}" ] && rm -rf "${old}"
    done
    if [ -n "${current}" ] && [ -d "${current}" ]; then
        echo "Seeding ${newdir} from ${current}"
        /usr/bin/rsync -a --link-dest="${current}/" "${current}/" "${newdir}/"
    elif [ -d "${live}" ] && [ ! -L "${live}" ]; then
        # First run: live exists as a real directory, not yet a symlink
        echo "Seeding ${newdir} from ${live} (real dir, first run)"
        /usr/bin/rsync -a --link-dest="${live}/" "${live}/" "${newdir}/"
    else
        mkdir -p "${newdir}"
    fi

    # Write g10k config pointing at the new versioned directory's parent
    # g10k will deploy into ${STAGINGBASE}/${branch} so we symlink newdir there
    ln -s "$(basename "${newdir}")" "${staging}"

    cat << EOF > "$r10kconf"
:cachedir: '${CACHEDIR}'
:sources:
  :main:
    remote: '${REMOTE}'
    basedir: '${STAGINGBASE}'
EOF

    /usr/local/bin/g10k -config "$r10kconf" -branch "$branch"
    local rc=$?
    rm -rf "${staging}"

    if [ $rc -ne 0 ]; then
        echo "g10k failed for branch ${branch}, aborting deploy" >&2
        rm -rf "${newdir}"
        return $rc
    fi

    # Atomically replace the live symlink using a temp symlink + mv -T
    local tmplnk
    tmplnk=$(mktemp -u "${BASEDIR}/.staging.${branch}.XXXXXX")
    ln -s "../$(basename "${STAGINGBASE}")/$(basename "${newdir}")" "${tmplnk}"
    echo "Atomically deploying ${branch} from ${newdir}"
    mv -T "${tmplnk}" "${live}"
    local mv_rc=$?

    if [ $mv_rc -ne 0 ]; then
        echo "Atomic swap failed for branch ${branch}" >&2
        rm -f "${tmplnk}"
        rm -rf "${newdir}"
        return $mv_rc
    fi

    # Clean up the old versioned directory
    if [ -n "${current}" ] && [ "${current}" != "${newdir}" ]; then
        echo "Removing old environment ${current}"
        rm -rf "${current}"
    fi

    return 0
}

flush_environment_cache () {
    local branch="${1}"

    [ -z "${PUPPET_SERVER}" ] && return 0

    local cert="${PUPPET_SSLDIR}/certs/${PUPPET_SERVER}.pem"
    local key="${PUPPET_SSLDIR}/private_keys/${PUPPET_SERVER}.pem"
    local cacert="${PUPPET_SSLDIR}/certs/ca.pem"

    if [ ! -f "${cert}" ] || [ ! -f "${key}" ] || [ ! -f "${cacert}" ]; then
        echo "Puppet SSL keys not found under ${PUPPET_SSLDIR}, skipping environment cache flush" >&2
        return 0
    fi

    echo "Flushing puppetserver environment cache for ${branch}"
    local http_code
    http_code=$(curl -s -o /dev/null -w "%{http_code}" \
        --cert "${cert}" \
        --key "${key}" \
        --cacert "${cacert}" \
        -X DELETE \
        "https://${PUPPET_SERVER}:8140/puppet-admin-api/v1/environment-cache?environment=${branch}")

    if [ "${http_code}" != "204" ]; then
        echo "Failed to flush environment cache for ${branch}: HTTP ${http_code}" >&2
        return 1
    fi

    echo "Environment cache flushed for ${branch}"
    return 0
}

if [[ $REF =~ 'refs/heads/' ]]; then
    branch=$(cut -d/ -f3 <<<"${REF}")
elif [ -n "${REF}" ]; then
    branch="${REF}"
else
    echo "g10k empty reference ${REF}"
    exit 1
fi

# Gitlab hooks return the after commit as the third argument.
# If it is all zeros, this is a delete event.
if [[ $EVENT =~ ^[[:xdigit:]]{40}$ ]]; then
    case ${BASH_REMATCH[0]} in
        "0000000000000000000000000000000000000000")
            event="delete"
            ;;
        *)
            event="push"
            ;;
    esac
else
    event="${EVENT}"
fi

case ${event} in
    ""|"push")
        deploy_branch "${branch}"
        deploy_rc=${?}
        [ ${deploy_rc} -eq 0 ] && flush_environment_cache "${branch}"
        notify "${deploy_rc}" "${branch}" "${event}"
        ;;
    "delete")
        rm -rf "${BASEDIR}/${branch}" "${STAGINGBASE}/${branch}"
        notify "${?}" "${branch}" "${event}"
        ;;
    *)
        echo "ignoring ${event} event"
        ;;
esac

exit 0
