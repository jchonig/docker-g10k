#!/bin/bash
# Pre-push hook: build the image and run smoke tests before allowing a push.
# Enable: git config core.hooksPath hooks

set -e

IMAGE=docker-g10k:pre-push-test
CONTAINER=g10k-pre-push-test

cleanup () {
    docker rm -f "${CONTAINER}" 2>/dev/null || true
    docker rmi -f "${IMAGE}" 2>/dev/null || true
}
trap cleanup EXIT

echo "==> Building image..."
docker build -t "${IMAGE}" .

echo "==> Starting container..."
docker run -d --name "${CONTAINER}" \
    -e HOOK_SECRET=testsecret \
    -p 9000:9000 \
    "${IMAGE}"
sleep 5

echo "==> Checking webhook process is running..."
docker exec "${CONTAINER}" pgrep webhook > /dev/null

echo "==> Testing branch parsing (refs/heads/production -> production)..."
docker exec "${CONTAINER}" bash -c '
    branch=$(cut -d/ -f3 <<<"refs/heads/production")
    [ "$branch" = "production" ] || { echo "FAIL: got $branch"; exit 1; }
    echo "PASS: branch=$branch"
'

echo "==> Testing bare branch ref passthrough..."
docker exec "${CONTAINER}" bash -c '
    REF="production"
    if [[ $REF =~ "refs/heads/" ]]; then
        branch=$(cut -d/ -f3 <<<"${REF}")
    elif [ -n "${REF}" ]; then
        branch="${REF}"
    else
        echo "FAIL: empty ref"; exit 1
    fi
    [ "$branch" = "production" ] || { echo "FAIL: got $branch"; exit 1; }
    echo "PASS: branch=$branch"
'

echo "==> Testing delete event detection (all-zero SHA)..."
docker exec "${CONTAINER}" bash -c '
    EVENT="0000000000000000000000000000000000000000"
    if [[ $EVENT =~ ^[[:xdigit:]]{40}$ ]] && \
       [ "${BASH_REMATCH[0]}" = "0000000000000000000000000000000000000000" ]; then
        echo "PASS: delete event detected"
    else
        echo "FAIL: delete event not detected"; exit 1
    fi
'

echo "==> Testing push event detection (non-zero SHA)..."
docker exec "${CONTAINER}" bash -c '
    EVENT="abc1230000000000000000000000000000000000"
    if [[ $EVENT =~ ^[[:xdigit:]]{40}$ ]] && \
       [ "${BASH_REMATCH[0]}" != "0000000000000000000000000000000000000000" ]; then
        echo "PASS: push event detected"
    else
        echo "FAIL: push event not detected"; exit 1
    fi
'

echo "==> Testing empty ref rejection..."
docker exec "${CONTAINER}" bash -c '
    REF=""
    if [[ $REF =~ "refs/heads/" ]]; then
        echo "FAIL: should not match"; exit 1
    elif [ -n "${REF}" ]; then
        echo "FAIL: should not be non-empty"; exit 1
    else
        echo "PASS: empty ref correctly rejected"
    fi
'

# Test HTTP 200 for github/gogs/payload using a nonexistent repo — these fire
# push-to-g10k asynchronously but we only verify the webhook accepted the request.
echo "==> Testing github webhook format (HTTP 200)..."
PAYLOAD='{"ref":"refs/heads/production","repository":{"ssh_url":"file:///tmp/puppet.git"}}'
SIG=$(printf '%s' "${PAYLOAD}" | openssl dgst -sha1 -hmac "testsecret" | awk '{print "sha1=" $2}')
HTTP=$(curl -s -o /dev/null -w "%{http_code}" \
    -X POST -H "Content-Type: application/json" \
    -H "X-Hub-Signature: ${SIG}" \
    -d "${PAYLOAD}" \
    http://localhost:9000/hooks/github)
[ "${HTTP}" = "200" ] || { echo "FAIL: github hook returned HTTP ${HTTP}"; exit 1; }
echo "PASS: github hook returned HTTP 200"

echo "==> Testing gogs webhook format (HTTP 200)..."
PAYLOAD='{"ref":"refs/heads/production","repository":{"ssh_url":"file:///tmp/puppet.git"}}'
SIG=$(printf '%s' "${PAYLOAD}" | openssl dgst -sha256 -hmac "testsecret" | awk '{print $2}')
HTTP=$(curl -s -o /dev/null -w "%{http_code}" \
    -X POST -H "Content-Type: application/json" \
    -H "X-Gogs-Signature: ${SIG}" \
    -H "X-Gogs-Event: push" \
    -d "${PAYLOAD}" \
    http://localhost:9000/hooks/gogs)
[ "${HTTP}" = "200" ] || { echo "FAIL: gogs hook returned HTTP ${HTTP}"; exit 1; }
echo "PASS: gogs hook returned HTTP 200"

echo "==> Testing payload webhook format (HTTP 200)..."
PAYLOAD='{"ref":"refs/heads/production","repository":{"ssh_url":"file:///tmp/puppet.git"},"secret":"testsecret"}'
HTTP=$(curl -s -o /dev/null -w "%{http_code}" \
    -X POST -H "Content-Type: application/json" \
    -d "${PAYLOAD}" \
    http://localhost:9000/hooks/payload)
[ "${HTTP}" = "200" ] || { echo "FAIL: payload hook returned HTTP ${HTTP}"; exit 1; }
echo "PASS: payload hook returned HTTP 200"

# Set up the puppet repo and verify a real end-to-end deployment via gitlab.
echo "==> Creating environments-staging directory..."
docker exec "${CONTAINER}" mkdir -p /etc/puppetlabs/code/environments-staging
docker exec "${CONTAINER}" chown abc:abc /etc/puppetlabs/code/environments-staging

echo "==> Setting up test puppet repo..."
docker exec "${CONTAINER}" bash -c '
    git config --global user.email "test@example.com"
    git config --global user.name "Test"
    mkdir -p /tmp/puppet-work
    cd /tmp/puppet-work
    git init
    git checkout -b production
'
docker cp test/Puppetfile "${CONTAINER}":/tmp/puppet-work/Puppetfile
docker exec "${CONTAINER}" bash -c '
    cd /tmp/puppet-work
    git add Puppetfile
    git commit -m "Test Puppetfile"
    git clone --bare . /tmp/puppet.git
    rm -rf /tmp/puppet-work
'

echo "==> Testing gitlab webhook (HTTP 200 + waiting for successful deployment)..."
PAYLOAD='{"ref":"refs/heads/production","repository":{"git_ssh_url":"file:///tmp/puppet.git"},"after":"abc123def456abc123def456abc123def456abc1"}'
# Capture log position before firing so we only watch new output
LOG_OFFSET=$(docker logs "${CONTAINER}" 2>&1 | wc -l | tr -d ' ')
HTTP=$(curl -s -o /dev/null -w "%{http_code}" \
    -X POST -H "Content-Type: application/json" \
    -H "X-Gitlab-Token: testsecret" \
    -d "${PAYLOAD}" \
    http://localhost:9000/hooks/gitlab)
[ "${HTTP}" = "200" ] || { echo "FAIL: gitlab hook returned HTTP ${HTTP}"; exit 1; }
echo "PASS: gitlab hook returned HTTP 200, waiting for deployment..."
# Poll new log lines for success or failure (allow 3 min)
PREV_OFFSET=${LOG_OFFSET}
for i in $(seq 1 18); do
    # Print any new container log lines so progress is visible
    CUR_COUNT=$(docker logs "${CONTAINER}" 2>&1 | wc -l | tr -d ' ')
    if [ "${CUR_COUNT}" -gt "${PREV_OFFSET}" ]; then
        docker logs "${CONTAINER}" 2>&1 | tail -n +$((PREV_OFFSET + 1)) | head -n $((CUR_COUNT - PREV_OFFSET))
        PREV_OFFSET=${CUR_COUNT}
    fi
    NEWLOGS=$(docker logs "${CONTAINER}" 2>&1 | tail -n +$((LOG_OFFSET + 1)))
    if echo "${NEWLOGS}" | grep -q "Atomically deploying"; then
        echo "PASS: deployment succeeded"
        exit 0
    fi
    if echo "${NEWLOGS}" | grep -q "Atomic swap failed\|g10k failed for branch"; then
        echo "FAIL: deployment failed"
        exit 1
    fi
    echo "  ... $((i * 10))s elapsed, waiting..."
    sleep 10
done
echo "FAIL: deployment timed out after 3 minutes"
docker logs "${CONTAINER}"
exit 1
